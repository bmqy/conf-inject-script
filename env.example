# 本地环境变量示例
# 复制此文件为 .env，并设置访问令牌和管理令牌。

# 订阅访问 token，仅用于 /:platform/:author/:token。
ACCESS_TOKEN=your_secret_token

# 管理后台 token，仅用于 /admin 登录和 /admin/api/*。
ADMIN_TOKEN=your_admin_token

# KV 命名空间 ID，用于动态生成 wrangler.toml。
KV_NAMESPACE_ID=YOUR_KV_NAMESPACE_ID

# Telegram 通知配置，留空则不发送通知。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 平台注入配置内容和配置源信息统一通过管理后台写入 Cloudflare KV。
